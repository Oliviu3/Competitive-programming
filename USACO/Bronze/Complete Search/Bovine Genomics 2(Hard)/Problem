
#include <vector>
#include <algorithm>
#include <cstdio>
#include <iostream>


using namespace std;
int bit(char c)
{
    if (c=='A')
    {
        return 0;
    }
    else if (c=='C')
    {
        return 1;
    }
    else if (c=='G')
    {
        return 2;
    }
    else if (c=='T')
    {
        return 3;
    }
}
int main()
{
    freopen("cownomics.in", "r", stdin);
    freopen( "cownomics.out", "w", stdout);
    int n,m,count=0;
    cin>>n>>m;
    vector<string> genp(n);
    vector<string> gens(n);
    vector<int> gen(64,0);
    for(int i=0;i<n;i++)
    {
        cin>>gens[i];
    }
    for(int i=0;i<n;i++)
    {
        cin>>genp[i];
    }
       for(int x=0;x<m-2;x++)
       {
           for(int y=x+1;y<m-1;y++)
           {
               for(int z=y+1;z<m;z++)
               {
                   gen.assign(64,0);
                   for (int i=0;i<n;i++)
                   {
                       gen[16*bit(gens[i][x])+4*bit(gens[i][y])+bit(gens[i][z])]=1;
                   }
                   bool flag=true;
                   for (int i=0;i<n;i++)
                   {
                       if (gen[16*bit(genp[i][x])+4*bit(genp[i][y])+bit(genp[i][z])]==1)
                       {
                           flag=false;
                       }
                   }
                   if(flag)
                       count++;
               }
           }
       }

    cout<<count;
}
