
#include <fstream>
#include <vector>
#include <algorithm>
using namespace std;
ifstream fin("diamond.in");
ofstream fout("diamond.out");


int main()
{
    int n,k;
    fin>>n>>k;
    vector<int> v(n);
    for(int i=0;i<n;i++)
    {
        fin>>v[i];
    }
    sort(v.begin(),v.end());
    int m=0,ma=0;
    for(int i=0;i<n;i++)
    {
        m=1;
        for(int j=i+1;j<n;j++)
        {
            if (v[j]-k<=v[i])
                m++;
        }
        if (m>ma)
            ma=m;
    }
    fout<<ma;

}
