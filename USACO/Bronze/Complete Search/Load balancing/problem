
#include <fstream>
#include <vector>
#include <algorithm>
using namespace std;
ifstream fin("balancing.in");
ofstream fout("balancing.out");

struct xy
{
   int x;
   int y;
};
int main()
{
   int n,m,ma=10000,rez=0;
   fin>>n>>m;
   int nw,ne,se,sw;
   vector<xy> v(n);
   for(int i=0;i<n;i++)
   {
      fin>>v[i].x>>v[i].y;
   }
   for(int x=m;x>0;x--)
   {
      nw=0,ne=0,se=0,sw=0;
      for (int y=m;y>0;y--)
      {
         if (v[y].x<x && v[y].y<y)
         {
            sw++;
         }
         else if (v[y].x>x && v[y].y<y)
         {
            se++;
         }
         else if (v[y].x<x && v[y].y>y)
         {
            nw++;
         }
         else if (v[y].x>x && v[y].y>y)
         {
            ne++;
         }
      }
      if (ne+nw+se+sw==m)
      {
         if (max({ne,nw,se,sw})-min({nw,ne,se,sw})<ma)
         {
            ma=max({nw,ne,se,sw})-min({ne,nw,se,sw});
            rez=max({nw,ne,se,sw});
         }
      }
   }
   fout<<rez;
}
