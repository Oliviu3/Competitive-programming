
#include <fstream>
#include <vector>
using namespace std;
ifstream fin("circlecross.in");
ofstream fout("circlecross.out");


int main()
{
    vector<int> st(26, -1);
    vector<int> fs(26, -1);
     string c;
    int ma=0;
    fin >> c;
    for (int i = 0; i<52; i++)
    {
        if (st[c[i]-'A']>-1 && fs[c[i]-'A']==-1)
        {
            fs[c[i]-'A']=i;
        }
        else if (st[c[i]-'A']==-1)
            st[c[i]-'A']=i;
    }
    for (int i = 0; i<26; i++)
    {
        for (int j = i+1; j<26; j++)
        {
            if ((st[j]>st[i] && st[j]<fs[i] && fs[j]>fs[i]) || (st[j]<st[i] && fs[j]>st[i] && fs[j]<fs[i]))
            {
                ma++;
            }
        }
    }
    fout << ma << "\n";
}
