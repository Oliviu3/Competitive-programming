#include <fstream>
#include <vector>
#include <algorithm>
using namespace std;
ifstream fin("measurement.in");
ofstream fout("measurement.out");

struct cows
{
    int day;
    string name,difference;
};
int comp(int &a ,int &b,int &c)
{
    int r=max({a,b,c});
    if (r==a && r==b && r==c)
        return 6;
    if (r==a && r==b)
        return 4;
    if (r==a && r==c)
        return 4;
    if (r==b && r==c)
        return 3;
    if (r==a)
        return 2;
    if (r==b)
        return 1;
    if (r==c)
        return 0;

}
int main()
{

    int n,ch=0;
    fin >> n;
    vector<cows> v;
    vector<int> output(3,7);
    cows c;
    while (fin>>c.day>>c.name>>c.difference)
    {
        v.push_back(c);
    }

    sort(v.begin(),v.end(),[](const cows &a,const cows &b)
    {
        return a.day<b.day;
    });
    int m=6;

    for (int i=0;i<n;i++)
    {
      if (v[i].name=="Bessie")
      {
          output[0]+=stoi(v[i].difference);
      }
        else if (v[i].name=="Elsie")
        {
            output[1]+=stoi(v[i].difference);
        }
        else
        {
            output[2]+=stoi(v[i].difference);
        }
        int r=comp(output[0],output[1],output[2]);
        if (r!=m)
        {
            ch++;
            m=r;
        }
    }
    fout << ch << endl;
}
